{
    "model": {
        "architecture": "beta_vae_features",
        "input_dim": 5,
        "max_length": 15000,
        "latent_dim": 128,
        "beta": 4.0,
        "num_classes": 2,
        "dropout_rate": 0.4,
        "encoding_type": "cse",
        "use_cse": true,
        "cse_d_model": 512,
        "cse_kernel_size": 9,
        "te_features_dim": 170,
        "nonb_features_dim": 178,
        "te_processor_hidden": [64, 32],
        "nonb_processor_hidden": [64, 32],
        "classifier_hidden": [128]
    },
    "data": {
        "lnc_fasta": "data/split_gencode_47/lnc_trainval.fa",
        "pc_fasta": "data/split_gencode_47/pc_trainval.fa",
        "lnc_test_fasta": "data/split_gencode_47/lnc_test.fa",
        "pc_test_fasta": "data/split_gencode_47/pc_test.fa",
        "te_features_csv": "data/processed_features/g47_te_features_clean.csv",
        "nonb_features_csv": "data/processed_features/g47_nonb_features_clean.csv",
        "te_scaler": "data/processed_features/g47_te_scaler.pkl",
        "nonb_scaler": "data/processed_features/g47_nonb_scaler.pkl"
    },
    "training": {
        "batch_size": 512,
        "num_epochs": 50,
        "learning_rate": 0.0001,
        "weight_decay": 1e-3,
        "alpha": 0.1,
        "beta": 0.0,
        "kl_anneal_epochs": 20,
        "kl_anneal_end": 4.0,
        "gamma_contrastive": 0.0,
        "gamma_classification": 1.0,
        "lambda_recon": 1.0,
        "temperature": 0.15,
        "reconstruction_loss": "mse",
        "early_stopping_patience": 10,
        "n_folds": 5,
        "random_state": 42,
        "n_bins": 5,
        "num_workers": 1
    },
    "optimizer": {
        "type": "Adam",
        "betas": [0.9, 0.999]
    },
    "scheduler": {
        "type": "ReduceLROnPlateau",
        "mode": "max",
        "factor": 0.5,
        "patience": 5,
        "min_lr": 1e-6
    },
    "output": {
        "experiment_name": "gencode_v47_experiments/beta_vae_features_g47"
    }
}