        "pc_test_fasta": "data/split_gencode_47/pc_test.fa"
    },
    "training": {
      "batch_size": 128,
      "num_epochs": 30,
      "learning_rate": 0.0005,
      "weight_decay": 0.0001,
      "alpha": 0.001,
      "beta": 4.0,
      "gamma_contrastive": 1,
      "gamma_classification": 100.0,
      "temperature": 0.15,
      "reconstruction_loss": "bce",
      "early_stopping_patience": 10,
      "random_state": 42,
      "num_workers": 1
        },
    "output": {
      "experiment_name": "gencode_v47_experiments/beta_vae_contrastive_g47"
