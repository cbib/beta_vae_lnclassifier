{
    "model": {
      "architecture": "beta_vae",
      "input_dim": 5,
      "max_length": 15000,
      "latent_dim": 128,
      "beta": 4.0,
      "num_classes": 2,
      "dropout_rate": 0.3,
      "embedding_dim": 128,
      "projection_dim": 64,
      "encoding_type": "cse",
      "use_cse": true,
      "cse_d_model": 128,
      "cse_kernel_size": 9
    },
    "data": {
      "lnc_fasta": "data/split_gencode_47/lnc_trainval.fa",
        "pc_fasta": "data/split_gencode_47/pc_trainval.fa",
